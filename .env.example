# Postgres connection string.
# Local dev: postgresql://<os-user>@localhost:5432/grouppic_dev?schema=public
# Production: use Neon's pooled connection string (Vercel > Storage > Neon integration)
DATABASE_URL="postgresql://user@localhost:5432/grouppic_dev?schema=public"

# Auth.js / NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# AES-256-GCM key used to encrypt LINE channel access tokens/secrets at rest.
# Any string works (it's passed through scrypt to derive a 32-byte key), but use a long
# random value in production, e.g.: openssl rand -base64 32
ENCRYPTION_KEY="generate-a-long-random-secret"

# Optional: used only by `npm run db:seed` to bootstrap the first superadmin account.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="changeme123"

# Google service account credentials for the one-way Sheets export (Phase 7).
# Paste the full JSON key contents as a single-line string.
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Optional: protects /api/cron/* routes from being called by anyone who guesses the URL.
# Vercel Cron automatically sends this as an Authorization: Bearer header when set.
# If unset, the cron routes are open (fine for local dev only).
# CRON_SECRET="generate-a-long-random-secret"

# Vercel Blob storage token, used to upload the registration form's header image and
# per-field example images. Add Blob storage to your Vercel project (Storage tab) — the
# token is generated and injected automatically there; for local dev, copy it via
# `vercel env pull` or paste it manually from the Vercel dashboard.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Optional: self-hosted photo storage (see pc-photo-server/README.md) as an alternative to
# Vercel Blob for group photos specifically. Leave both unset to keep using Vercel Blob (default).
# NEXT_PUBLIC_PC_PHOTO_STORAGE_URL="https://grouppic.example.com"
# PC_PHOTO_STORAGE_SECRET="must-match-UPLOAD_SECRET-in-pc-photo-server/.env-exactly"
