// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth / admin users
// ---------------------------------------------------------------------------

enum AdminRole {
  SUPERADMIN
  UNIVERSITY_ADMIN
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(UNIVERSITY_ADMIN)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  universities AdminUserUniversity[]

  @@map("admin_users")
}

model AdminUserUniversity {
  adminUserId  String
  universityId String
  createdAt    DateTime @default(now())

  adminUser  AdminUser  @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@id([adminUserId, universityId])
  @@map("admin_user_universities")
}

// ---------------------------------------------------------------------------
// Universities & configurable form schema
// ---------------------------------------------------------------------------

model University {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  isActive       Boolean  @default(true)
  headerImageUrl String? // banner image shown at the top of the registration form
  themeColor     String? // hex color (e.g. "#4f46e5") used to brand this university's registration form; defaults to the app's indigo when unset
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  formFields        FormFieldDefinition[]
  channelPool       UniversityChannelPool[]
  registrants       Registrant[]
  rules             Rule[]
  admins            AdminUserUniversity[]
  sheetExportConfig SheetExportConfig?
  groupPhotos       GroupPhoto[]
  legacyReferences  GroupPhotoLegacyReference[]
  photoEvents       PhotoEvent[]

  @@map("universities")
}

/// Shared across every university — this operator manages several universities and reuses the
/// same recurring messages (e.g. a promo banner) across all of them.
model MessageTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  body      String
  imageUrl  String?
  linkUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("message_templates")
}

enum FormFieldType {
  TEXT
  NUMBER
  SELECT
  DATE
  DATETIME
  PHONE
  EMAIL
}

model FormFieldDefinition {
  id           String        @id @default(cuid())
  universityId String
  key          String // used as the key inside Registrant.data JSON
  label        String
  description  String? // optional helper text shown under the label on the registration form
  imageUrl     String? // optional image shown under the description (e.g. an example photo)
  fieldType    FormFieldType @default(TEXT)
  options      Json? // for SELECT fields: string[]
  isRequired   Boolean       @default(true)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([universityId, key])
  @@map("form_field_definitions")
}

// ---------------------------------------------------------------------------
// LINE channels & channel pools
// ---------------------------------------------------------------------------

model Channel {
  id                     String    @id @default(cuid())
  name                   String
  lineChannelId          String    @unique
  accessTokenEncrypted   String
  accessTokenExpiresAt   DateTime? // set only for tokens we auto-issued (short-lived, ~30d); null = manually-issued long-lived token or not yet issued
  channelSecretEncrypted String
  liffId                 String // "" until auto-created
  monthlyFreeQuota       Int       @default(300)
  allowOverage           Boolean   @default(true)
  isActive               Boolean   @default(true)
  lineBasicId            String?
  lineDisplayName        String?
  linePictureUrl         String?
  richMenuId             String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  universityPool UniversityChannelPool[]
  registrants    Registrant[]
  usageCounters  ChannelUsageCounter[]
  messageJobs    MessageJob[]
  messageLogs    MessageLog[]
  followers      LineFollower[]

  @@map("channels")
}

/// Every LINE user who has ever followed this channel's OA, tracked independently of
/// Registrant — a follow event alone creates no Registrant row (that only happens once someone
/// actually submits the registration form), so without this there was no way to see "added the
/// LINE friend but never registered." Kept (not deleted) on unfollow, just timestamped, so a
/// re-follow doesn't look like a brand-new person. Not university-scoped directly — since one
/// channel can serve multiple universities, "unregistered for university X" is computed by
/// joining against Registrant per-university at query time (see getUnregisteredFollowers).
model LineFollower {
  id           String    @id @default(cuid())
  channelId    String
  lineUserId   String
  displayName  String?
  pictureUrl   String?
  followedAt   DateTime  @default(now())
  unfollowedAt DateTime?
  updatedAt    DateTime  @updatedAt

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, lineUserId])
  @@index([channelId])
  @@map("line_followers")
}

// LINE requires LIFF apps to live on a separate LINE Login channel (can't be added directly to
// a Messaging API channel) — this project shares ONE Login channel across every university's
// LIFF app, so its credentials are stored once here rather than per-Channel. Always exactly one
// row (id fixed to "singleton"), upserted.
model LineLoginChannel {
  id                     String    @id @default("singleton")
  channelId              String
  channelSecretEncrypted String
  accessTokenEncrypted   String    @default("")
  accessTokenExpiresAt   DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@map("line_login_channel")
}

model UniversityChannelPool {
  universityId String
  channelId    String
  weight       Int      @default(1)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  channel    Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([universityId, channelId])
  @@map("university_channel_pools")
}

model ChannelUsageCounter {
  id           String   @id @default(cuid())
  channelId    String
  yearMonth    String // e.g. "2026-07"
  messagesSent Int      @default(0)
  updatedAt    DateTime @updatedAt

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, yearMonth])
  @@map("channel_usage_counters")
}

// ---------------------------------------------------------------------------
// Registrants
// ---------------------------------------------------------------------------

enum RegistrantStatus {
  PENDING
  CONFIRMED
  PROBLEM
  CANCELLED
}

/// Post-tagging photo-delivery lifecycle — deliberately separate from RegistrantStatus (which
/// tracks registration-quality/rule-engine concerns and stays untouched) since this is about
/// what happens to a graduate's PRINTED photo after the event, not their registration itself.
enum DeliveryStatus {
  REGISTERED // default — no delivery-related action taken yet
  PHOTO_ORDERED
  PHOTO_RECEIVED
  NO_SHOW
  OTHER
}

model Registrant {
  id             String           @id @default(cuid())
  universityId   String
  channelId      String?
  lineUserId     String?
  isFriend       Boolean          @default(false)
  displayName    String?
  data           Json             @default("{}")
  status         RegistrantStatus @default(PENDING)
  deliveryStatus DeliveryStatus   @default(REGISTERED)
  // Never set at registration time — stamped exactly once, the first time this registrant is
  // successfully matched (matchSource=REGISTRANT) against a tag belonging to a specific
  // PhotoEvent (see resolveTagMatch.ts's bootstrap-then-stick mechanism). Sticky: once stamped,
  // auto-sync must never silently reassign it to a different event.
  photoEventId   String?
  registeredAt   DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  university     University      @relation(fields: [universityId], references: [id], onDelete: Cascade)
  channel        Channel?        @relation(fields: [channelId], references: [id])
  photoEvent     PhotoEvent?     @relation(fields: [photoEventId], references: [id], onDelete: SetNull)
  ruleExecutions RuleExecution[]
  messageJobs    MessageJob[]
  messageLogs    MessageLog[]
  groupPhotoTags GroupPhotoTag[]

  @@index([universityId, lineUserId])
  @@index([universityId, status])
  @@index([photoEventId])
  @@map("registrants")
}

// ---------------------------------------------------------------------------
// Rule engine
// ---------------------------------------------------------------------------

enum RuleTrigger {
  ON_REGISTRATION
  SCHEDULED_TICK
}

model Rule {
  id              String      @id @default(cuid())
  universityId    String
  name            String
  isActive        Boolean     @default(true)
  trigger         RuleTrigger @default(ON_REGISTRATION)
  conditionTree   Json // {"op":"AND"|"OR","conditions":[...]}
  messageTemplate String
  scheduleConfig  Json? // { relativeToField: string, offsetMinutes: number } for SCHEDULED_TICK
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  university University      @relation(fields: [universityId], references: [id], onDelete: Cascade)
  executions RuleExecution[]

  @@index([universityId, isActive])
  @@map("rules")
}

enum RuleExecutionStatus {
  PENDING
  SENT
  FAILED
  SKIPPED_QUOTA
  SKIPPED_NOT_REACHABLE
}

model RuleExecution {
  id           String              @id @default(cuid())
  ruleId       String
  registrantId String
  status       RuleExecutionStatus @default(PENDING)
  attemptedAt  DateTime            @default(now())
  sentAt       DateTime?
  errorDetail  String?

  rule       Rule        @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  registrant Registrant  @relation(fields: [registrantId], references: [id], onDelete: Cascade)
  messageJob MessageJob?

  @@unique([ruleId, registrantId])
  @@map("rule_executions")
}

// ---------------------------------------------------------------------------
// Message sending pipeline
// ---------------------------------------------------------------------------

enum MessageJobSource {
  RULE
  MANUAL
}

enum MessageJobStatus {
  QUEUED
  SENDING
  SENT
  FAILED
}

model MessageJob {
  id              String           @id @default(cuid())
  registrantId    String
  channelId       String
  source          MessageJobSource @default(MANUAL)
  ruleExecutionId String?          @unique
  body            String // may be "" when the send is image-only
  imageUrl        String? // optional image attachment for manual/bulk sends — counts as its own message against quota when set
  linkUrl         String? // when set alongside imageUrl, sent as a tappable Flex image (like a banner ad) instead of a plain image message
  status          MessageJobStatus @default(QUEUED)
  attempts        Int              @default(0)
  lastError       String?
  createdAt       DateTime         @default(now())
  processedAt     DateTime?

  registrant    Registrant     @relation(fields: [registrantId], references: [id], onDelete: Cascade)
  channel       Channel        @relation(fields: [channelId], references: [id])
  ruleExecution RuleExecution? @relation(fields: [ruleExecutionId], references: [id])

  @@index([status, createdAt])
  @@map("message_jobs")
}

model MessageLog {
  id                    String   @id @default(cuid())
  registrantId          String
  channelId             String
  body                  String
  lineApiResponseStatus Int?
  createdAt             DateTime @default(now())

  registrant Registrant @relation(fields: [registrantId], references: [id], onDelete: Cascade)
  channel    Channel    @relation(fields: [channelId], references: [id])

  @@index([registrantId])
  @@map("message_logs")
}

// ---------------------------------------------------------------------------
// Google Sheets one-way export mirror
// ---------------------------------------------------------------------------

enum SheetSyncStatus {
  SUCCESS
  FAILED
}

model SheetExportConfig {
  id             String           @id @default(cuid())
  universityId   String           @unique
  googleSheetId  String
  lastSyncedAt   DateTime?
  lastSyncStatus SheetSyncStatus?
  lastSyncError  String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@map("sheet_export_configs")
}

// ---------------------------------------------------------------------------
// Phase 3: photo events (multi-event scaling within one university)
// ---------------------------------------------------------------------------

enum PhotoEventStatus {
  ACTIVE
  ARCHIVE_READY // close-out archive job finished, live data not yet deleted
  ARCHIVED // live data deleted, only archiveFileUrl remains
}

/// One academic-year photography event for a university (e.g. "KKU67"). Exists because the same
/// university can run this event more than once with overlapping dates AND overlapping
/// group_photo_index code ranges (e.g. KKU67 codes 1000-5000, KKU68 codes 3000-7000, same LINE
/// channel) — nothing about code or channel alone can disambiguate which event a given code
/// belongs to, so this is the explicit scoping unit resolveTagMatch.ts's matching maps use.
model PhotoEvent {
  id             String           @id @default(cuid())
  universityId   String
  code           String // short label shown throughout the admin UI, e.g. "KKU67"
  label          String? // optional longer description, e.g. "ปีการศึกษา 2567"
  startDate      DateTime // registration-date window used to bootstrap-match unassigned registrants — see resolveTagMatch.ts
  endDate        DateTime
  codeRangeMin   Int? // informational sanity-check hint only — never hard-enforced, ranges legitimately overlap across events
  codeRangeMax   Int?
  status         PhotoEventStatus @default(ACTIVE)
  archiveFileUrl String? // set once a close-out archive job succeeds
  archivedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  university       University                  @relation(fields: [universityId], references: [id], onDelete: Cascade)
  groupPhotos      GroupPhoto[]
  legacyReferences GroupPhotoLegacyReference[]
  registrants      Registrant[]
  archiveJobs      PhotoEventArchiveJob[]

  @@unique([universityId, code])
  @@map("photo_events")
}

enum PhotoEventArchiveStage {
  EXPORTING_DATA
  COPYING_IMAGES
  EMBEDDING_FACES
  DONE
  FAILED
}

/// Close-out archive job: builds a durable, self-contained backup of one PhotoEvent (a data.json
/// manifest with every DB row + copies of every GroupPhoto image, parked under its own
/// archives/<eventId>/ Blob prefix independent of the live GroupPhoto.imageUrl) so the live DB
/// rows can be safely deleted afterward to reduce server load, and so the event can be fully
/// reimported later. Processed a tick at a time by api/cron/process-photo-event-archive-jobs
/// (same claim-one-job pattern as GroupPhotoAutoTagJob) since a real event's images can total
/// hundreds of MB — too large to safely build in memory within one serverless invocation.
/// EMBEDDING_FACES (before DONE) backs up row-0, named, non-problem tags into
/// FacultyFaceProfile via the self-hosted PC server's /embed-face — see that model's docstring.
model PhotoEventArchiveJob {
  id           String                 @id @default(cuid())
  photoEventId String
  stage        PhotoEventArchiveStage @default(EXPORTING_DATA)
  // True when this job was started via the standalone "ดึงเข้าคลังใบหน้า" button (starts directly
  // at EMBEDDING_FACES, skipping EXPORTING_DATA/COPYING_IMAGES) rather than a full close-out —
  // on completion the cron route must NOT flip PhotoEvent.status to ARCHIVE_READY, since nothing
  // was actually backed up/closed out, only the face bank was updated.
  facesOnly    Boolean                @default(false)
  imagesTotal  Int                    @default(0)
  imagesDone   Int                    @default(0)
  facesTotal   Int                    @default(0)
  facesDone    Int                    @default(0)
  errorMessage String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  completedAt  DateTime?

  photoEvent PhotoEvent @relation(fields: [photoEventId], references: [id], onDelete: Cascade)

  @@index([stage])
  @@index([photoEventId])
  @@map("photo_event_archive_jobs")
}

// ---------------------------------------------------------------------------
// Phase 2: group photo tagging
// ---------------------------------------------------------------------------

/// One faculty/group's graduation photo for a university. A university typically has 10-24 of
/// these (one per faculty/group), each tagged independently.
model GroupPhoto {
  id           String           @id @default(cuid())
  universityId String
  // Every photo belongs to exactly one event. Existing rows were backfilled to a synthetic
  // per-university PhotoEvent by the `add_photo_event` migration itself (see its migration.sql).
  photoEventId String
  name         String // also used verbatim as the export's "คณะ" column
  title        String? // display heading shown on the tagging/validate/photo-view pages; may differ from `name` — falls back to `name` when unset
  imageUrl     String // plain string, storage-agnostic — swapping backends later is a data change, not a schema change
  imageWidth   Int
  imageHeight  Int
  sortOrder    Int              @default(0)
  status       GroupPhotoStatus @default(NOT_STARTED) // admin-set; DONE freezes auto-sync (see autoSyncGroupPhotoTags)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  university   University               @relation(fields: [universityId], references: [id], onDelete: Cascade)
  photoEvent   PhotoEvent               @relation(fields: [photoEventId], references: [id], onDelete: Cascade)
  tags         GroupPhotoTag[]
  shareLinks   GroupPhotoShareLink[]
  titleHistory GroupPhotoTitleHistory[]
  autoTagJobs  GroupPhotoAutoTagJob[]

  @@index([universityId])
  @@index([photoEventId])
  @@map("group_photos")
}

enum GroupPhotoAutoTagStage {
  OCR
  ACCEPTING
  FIXING_ORDER
  DONE
  FAILED
}

/// Background job for the mobile "express upload" flow: after a photo is uploaded+cropped, bulk
/// OCR + accept-all + fix-row-order run here instead of client-side, so the admin can close the
/// app/lock their phone and the pipeline keeps going — processed a bit at a time by
/// api/cron/process-group-photo-auto-tag-jobs (no session, no browser tab required). FAILED is a
/// terminal state for v1 (no auto-retry) — the photo's own tagging page still has the same manual
/// buttons as a fallback if a job fails.
model GroupPhotoAutoTagJob {
  id           String                 @id @default(cuid())
  groupPhotoId String
  stage        GroupPhotoAutoTagStage @default(OCR)
  tilesTotal   Int
  tilesDone    Int                    @default(0)
  errorMessage String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  completedAt  DateTime?

  groupPhoto GroupPhoto             @relation(fields: [groupPhotoId], references: [id], onDelete: Cascade)
  hits       GroupPhotoAutoTagHit[]

  @@index([stage])
  @@index([groupPhotoId])
  @@map("group_photo_auto_tag_jobs")
}

/// One row per OCR hit accumulated across cron ticks during a job's OCR stage — coordinates are
/// already mapped to full-photo pixel space (not tile-local) so the ACCEPTING stage doesn't need
/// to remember each hit's originating tile geometry.
model GroupPhotoAutoTagHit {
  id        String  @id @default(cuid())
  jobId     String
  tileIndex Int
  code      String
  x         Float
  y         Float
  confident Boolean @default(true) // model's own self-reported read confidence (see bulkCardOcr.ts's prompt) — carried through to GroupPhotoTag.ocrLowConfidence when this hit is accepted into a real tag

  job GroupPhotoAutoTagJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("group_photo_auto_tag_hits")
}

/// One entry per title change (admin tagging page or the public /validate page) — mirrors
/// GroupPhotoTagHistory's shape/intent exactly, just for the photo's title instead of a tag's
/// name. `title: null` records a change back to "unset" (falls back to displaying `name`).
model GroupPhotoTitleHistory {
  id           String           @id @default(cuid())
  groupPhotoId String
  title        String?
  source       TagHistorySource
  createdAt    DateTime         @default(now())

  groupPhoto GroupPhoto @relation(fields: [groupPhotoId], references: [id], onDelete: Cascade)

  @@index([groupPhotoId, createdAt])
  @@map("group_photo_title_history")
}

enum GroupPhotoStatus {
  NOT_STARTED
  NEEDS_EDIT
  DONE
}

enum TagMatchSource {
  REGISTRANT
  LEGACY_REFERENCE
  MANUAL
}

enum TagHistorySource {
  ADMIN
  AUTO_SYNC
  PUBLIC_LINK
}

/// One tagged person within a GroupPhoto — mirrors the legacy desktop tool's data model
/// (name/code/row/order/X/Y) so exports stay byte-compatible with existing downstream files.
model GroupPhotoTag {
  id                     String         @id @default(cuid())
  groupPhotoId           String
  code                   String // raw as typed/OCR'd, e.g. "B1710"
  normalizedCode         String // digits-only, computed server-side — powers indexed duplicate/match queries
  name                   String
  row                    Int // แถว — 0 = front sitting row, 1+ = standing rows behind
  order                  Int // ลำดับ — position within the row, left to right
  x                      Float // full-resolution pixel space, matches legacy export exactly
  y                      Float
  registrantId           String? // set when matched against a live Phase-1 Registrant (enables direct LINE send)
  matchSource            TagMatchSource @default(MANUAL)
  nameOverridden         Boolean        @default(false) // a human explicitly saved a name different from what the current registrant/legacy-reference match would auto-fill — auto-sync (autoSyncGroupPhotoTags/syncRegistrantGroupPhotoTags) must never silently revert it back, even though it keeps registrantId/matchSource itself in sync with whichever code the tag currently has
  editedViaPublicLink    Boolean        @default(false)
  publicLinkEditedAt     DateTime?
  confirmedViaPublicLink Boolean        @default(false) // reviewer opened the /validate name-edit dialog and confirmed the name as-is (no change) — distinct from editedViaPublicLink so the sidebar badge can tell "confirmed correct" apart from "actually changed"
  confirmedAt            DateTime?
  reportedProblem        Boolean        @default(false) // graduate flagged this from their own /photo-view link (wrong photo/code, can't self-fix)
  reportedAt             DateTime?
  problemAcknowledged    Boolean        @default(false) // admin explicitly reviewed this tag and confirmed it's fine — validateTags() excludes it from the problem list entirely (both DUPLICATE_CODE and UNMATCHED_CODE), on both the admin tag page and the public /validate page, even though the underlying duplicate/unmatched condition is still technically true in the data. Toggled via the admin edit dialog only — not exposed on any public page.
  ocrLowConfidence       Boolean        @default(false) // set true when this tag was created from a bulk-OCR (or mobile background auto-tag) hit the model itself flagged as an uncertain read — surfaced as an amber ring/badge on the admin tag page so an admin can go double-check the card. Never set by a manual dialog save (create or edit) — any deliberate admin save clears it, since that IS the human review this flag is asking for.
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  groupPhoto GroupPhoto             @relation(fields: [groupPhotoId], references: [id], onDelete: Cascade)
  registrant Registrant?            @relation(fields: [registrantId], references: [id], onDelete: SetNull)
  history    GroupPhotoTagHistory[]

  // Deliberately no @@unique on (groupPhotoId, normalizedCode) — duplicates are a valid,
  // expected transient state that the validator must be able to detect and flag.
  @@index([groupPhotoId, normalizedCode])
  @@index([groupPhotoId, row, order])
  @@map("group_photo_tags")
}

/// One snapshot per save of a GroupPhotoTag's name/code/position — lets an admin see what a mark
/// point used to say before an edit (manual, auto-synced from a registrant/reference update, or
/// via the public share-link) without needing full field-by-field diffing.
model GroupPhotoTagHistory {
  id        String           @id @default(cuid())
  tagId     String
  code      String
  name      String
  row       Int
  order     Int
  source    TagHistorySource
  createdAt DateTime         @default(now())

  tag GroupPhotoTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@index([tagId, createdAt])
  @@map("group_photo_tag_history")
}

/// Per-university reference data imported once from a legacy Google Form export, used ONLY for
/// name lookup during tagging. Deliberately separate from Registrant — some universities never
/// had LIFF/LINE registration at all, and these people must never gain LINE-messaging capability
/// they don't actually have.
model GroupPhotoLegacyReference {
  id             String                @id @default(cuid())
  universityId   String
  // Every import is an explicit per-upload admin action that picks the target event. Existing
  // rows were backfilled to a synthetic per-university PhotoEvent by the `add_photo_event`
  // migration itself (see its migration.sql).
  photoEventId   String
  name           String
  code           String // raw as parsed, plain digits per the real sample format
  normalizedCode String
  phone          String?
  source         LegacyReferenceSource @default(EXCEL_FILE)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  photoEvent PhotoEvent @relation(fields: [photoEventId], references: [id], onDelete: Cascade)

  @@index([universityId, normalizedCode])
  @@index([photoEventId, normalizedCode])
  @@map("group_photo_legacy_references")
}

enum LegacyReferenceSource {
  EXCEL_FILE
  GOOGLE_SHEET
}

/// A public, unauthenticated link scoped to one GroupPhoto's flagged/problem tags. Anyone with
/// the link can view and edit those rows directly — no login. No snapshot of which tags are
/// "problem" tags is stored here; that's computed live by the same validator the admin UI uses.
model GroupPhotoShareLink {
  id           String   @id @default(cuid())
  groupPhotoId String
  token        String   @unique
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  groupPhoto GroupPhoto @relation(fields: [groupPhotoId], references: [id], onDelete: Cascade)

  @@map("group_photo_share_links")
}

// ---------------------------------------------------------------------------
// Phase 3.4: faculty face recognition bank
// ---------------------------------------------------------------------------

/// Durable, cross-year bank of recognized faculty faces — global, NOT scoped to one
/// university/event, since the same professor legitimately recurs across different
/// universities/years. Built up by PhotoEventArchiveJob's EMBEDDING_FACES stage during event
/// close-out: every row-0 (front row), named, non-problem tag gets its face cropped and embedded
/// via the self-hosted PC server's POST /embed-face (InsightFace/ArcFace, see
/// pc-photo-server/spike-face-recognition for the de-risk spike that validated this approach on
/// real data — 0.85 same-person vs 0.39 different-person cosine similarity). Looked up later from
/// TagEditDialog's "ค้นหาจากใบหน้า" button when a future event's front-row tag can't be matched by
/// code, to suggest "this might be the same person as an earlier year."
///
/// `embedding` is a plain Float[] (512-d), not pgvector — pgvector IS available on this Neon
/// project (confirmed `SELECT * FROM pg_available_extensions WHERE name='vector'`, v0.8.0) but
/// deliberately not enabled: expected row count here is a few hundred to low thousands (unique
/// faculty, not a large-scale dataset), where brute-force cosine similarity computed in Node is
/// already sub-10ms — no meaningful benefit from a native vector index at this scale, and this
/// avoids adding a native Postgres extension dependency local dev doesn't have installed.
///
/// Upserted by exact `name` match (keyed `@unique`) — a real, accepted limitation: two different
/// faculty sharing the exact same name string would collide. Acceptable for v1 given how rarely
/// this occurs among a university's teaching staff; an admin can resolve a collision manually.
model FacultyFaceProfile {
  id                       String    @id @default(cuid())
  name                     String    @unique
  embedding                Float[]
  sourceCropUrl            String // face crop saved alongside the embedding so an admin can visually confirm a search match
  lastSeenPhotoEventId     String? // informational only — not a real FK (the referenced PhotoEvent may later be deleted by close-out; this profile must survive that)
  // The GroupPhotoTag this profile's embedding was last derived from, plus that tag's own
  // updatedAt at the time — lets a re-run (clicking "ดึงเข้าคลังใบหน้า" again, or running a full
  // archive after already building the face bank standalone) skip the expensive PC-server
  // crop+embed round trip entirely when the candidate tag hasn't changed at all since. Not a real
  // FK — the tag can be deleted/re-tagged later, in which case this just stops matching and the
  // next run re-embeds normally.
  lastEmbeddedTagId        String?
  lastEmbeddedTagUpdatedAt DateTime?
  timesMatched             Int       @default(1)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@map("faculty_face_profiles")
}
