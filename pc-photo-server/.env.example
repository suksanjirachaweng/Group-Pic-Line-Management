# Must match PC_PHOTO_STORAGE_SECRET in the main app's .env exactly — this is what proves an
# upload request really came from your Next.js app and not some random visitor to your domain.
# Generate with: openssl rand -hex 32
UPLOAD_SECRET="generate-a-long-random-secret"

# Public HTTPS URL this server is reachable at (through the Cloudflare Tunnel).
PUBLIC_BASE_URL="https://grouppic.newsalon1999.com"

# Local port the Cloudflare Tunnel's published application route points to. Change only if it
# conflicts with another local service (and update the tunnel's route to match).
PORT=8793

# Where uploaded photos are stored on disk. Defaults to ./storage next to server.js.
# STORAGE_DIR="C:\\GroupPicPhotos\\storage"
